{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",

    "baseUrl": ".", 
    "paths": {
      "@/*": ["src/*"]
    },

    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "ignoreDeprecations": "6.0"
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}